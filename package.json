{
    "name": "asma-ui-icons",
    "publishConfig": {
        "access": "public"
    },
    "version": "0.2.4",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist/**/*",
        "dist/style.css",
        "tw-configs/**/*"
    ],
    "keywords": [],
    "author": "asma-team",
    "types": "./dist/index.d.ts",
    "main": "./dist/asma-ui-icons.es.js",
    "module": "./dist/asma-ui-icons.es.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/asma-ui-icons.es.js"
        },
        "./icons": {
            "types": "./dist/src/components/icons/index.d.ts",
            "default": "./dist/components/icons/index.js"
        },
        "./icons/*": {
            "types": "./dist/src/components/icons/*/index.d.ts",
            "default": "./dist/components/icons/*/index.js"
        },
        "./dist/asma-ui-icons.es.js": "./dist/asma-ui-icons.es.js",
        "./dist/style.css": "./dist/style.css",
        "./tw-configs/twConfigs.json": "./tw-configs/twConfigs.json"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && rm -rf ./dist && vite build",
        "preview": "vite preview",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "version": "echo $npm_package_version",
        "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
        "prettier": "prettier --write src//**/*.{ts,tsx,scss} --config ./.prettierrc",
        "storybook": "storybook dev -p 6006",
        "storybook:no-browser": "storybook dev -p 6006 --no-open",
        "storybook:node18": "export NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "storybook:node18:win": "set NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "build-storybook": "export NODE_OPTIONS=--max_old_space_size=6240 && storybook build",
        "test-storybook": "test-storybook",
        "changeset:pre-beta": "changeset pre enter beta",
        "changeset:pre-exit": "changeset pre exit",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "changeset:status": "changeset status"
    },
    "license": "UNLICENSED",
    "dependencies": {},
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.1",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@mui/material": "^5.13.7",
        "@rollup/plugin-terser": "^1.0.0",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/react": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@storybook/test-runner": "^0.24.3",
        "@tippyjs/react": "^4.2.6",
        "@types/node": "^25.5.2",
        "@types/react": "^18.0.37",
        "@types/react-copy-to-clipboard": "^5.0.7",
        "@types/react-dom": "^18.0.11",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitejs/plugin-react": "^6.0.1",
        "asma-core-ui": "3.1.0-3",
        "@tailwindcss/postcss": "^4.2.2",
        "axe-playwright": "^2.2.2",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-storybook": "^10.3.5",
        "postcss": "^8.5.9",
        "prop-types": "^15.8.1",
        "react-copy-to-clipboard": "^5.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hot-toast": "^2.4.1",
        "rollup-plugin-typescript2": "^0.37.0",
        "storybook": "^10.3.5",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2",
        "typescript-plugin-css-modules": "^5.0.1",
        "vite": "^8.0.8",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "@emotion/react": "^11.*",
        "@emotion/styled": "^11.*",
        "@mui/material": "^5.*",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "repository": {
        "url": "https://github.com/Carasent-ASMA/asma-ui-icons.git"
    },
    "resolutions": {
        "@types/node": "18.0.3"
    }
}
